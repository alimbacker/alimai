# ── Server ─────────────────────────────────────────────
PORT=4000
# Required. Any long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=change_this_to_a_long_random_string

# ── Admin access ──────────────────────────────────────
# Comma-separated emails that get admin rights automatically. Set this to
# YOUR email to bootstrap the first admin, then use the Admin Dashboard to
# create/promote more admins. Example: ADMIN_EMAILS=you@example.com
ADMIN_EMAILS=

# ── Semantic search for Brains (RAG embeddings) ───────
# Set ONE of these to enable meaning-based Brain search. Without either,
# Brains still work using keyword matching.
#  • GEMINI_API_KEY — FREE tier, no billing. Get it in ~1 min at
#    https://aistudio.google.com/apikey  (uses gemini-embedding-001).
#  • OPENAI_API_KEY — paid but very cheap; also unlocks GPT-4o in the picker.
# If both are set, Gemini is used.
GEMINI_API_KEY=

# ── Google sign-in (optional) ─────────────────────────
# Enables the "Continue with Google" button. Create an OAuth 2.0 Client ID
# (type: Web application) at https://console.cloud.google.com/apis/credentials,
# add your site to "Authorized JavaScript origins" (e.g. https://your-domain and
# http://localhost:5173 for dev). Then set the SAME client ID in BOTH places:
#   • GOOGLE_CLIENT_ID       — server, verifies the Google token.
#   • VITE_GOOGLE_CLIENT_ID  — frontend BUILD-time var, renders the button.
# Without these the app still works with email + password; the Google button
# shows a short "set me up" note instead.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ── Live web search (up-to-date answers) ──────────────
# Lets general (non-Brain) answers use CURRENT info instead of the model's
# training memory — e.g. "who is the CM of Tamil Nadu", prices, "latest ...".
# Set ONE key. Without either, Alim still answers (from model memory) but is
# told today's date so it won't state stale facts as current.
#  • TAVILY_API_KEY — recommended. Free tier, LLM-ready results: https://tavily.com
#  • BRAVE_API_KEY  — Brave Search API (free tier available).
TAVILY_API_KEY=
# BRAVE_API_KEY=
# When to search on general questions: auto (default, factual questions only),
# always (every general message), or off.
# WEB_SEARCH_MODE=auto

# ── Retrieval / Smart-routing sensitivity (optional) ──
# How readily Smart mode grounds an answer in a Brain vs. answering generally.
# Defaults are sane; only touch these if routing feels too eager or too shy.
#   *_INCLUDE = a chunk at/above this is pulled in as context once we ground.
#   *_ROUTE   = the BEST hit must clear this (higher) bar for Smart to route to a
#               brain at all; below it, Alim answers from general knowledge
#               instead of saying "not in my knowledge base".
# SEMANTIC scores are cosine similarity (0-1); KEYWORD scores are query coverage
# (0-1). Raise the ROUTE values to make grounding stricter.
# MIN_SEMANTIC_SCORE=0.55
# ROUTE_SEMANTIC_SCORE=0.68
# MIN_KEYWORD_SCORE=0.34
# ROUTE_KEYWORD_SCORE=0.5

# ── Model provider API keys ───────────────────────────
# Add at least ONE. Only models whose key is set appear in the app.
# Groq has a generous free tier and powers the GPT-OSS models by default:
GROQ_API_KEY=
ANTHROPIC_API_KEY=
# (OPENAI_API_KEY can also power Brain embeddings — see the section above.)
OPENAI_API_KEY=

# ── Database (libSQL / Turso) ─────────────────────────
# LOCAL DEV: leave these blank — the app uses a local file `alim.sqlite`.
# PRODUCTION (Vercel): REQUIRED. Create a free DB at https://turso.tech, then:
#   turso db create alim-ai
#   turso db show alim-ai --url        -> TURSO_DATABASE_URL (libsql://...)
#   turso db tokens create alim-ai     -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
